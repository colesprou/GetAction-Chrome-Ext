# Optic Odds (api.opticodds.com). The env var keeps its legacy name.
ODDSJAM_API_KEY=replace_me
OPTIC_ODDS_BASE_URL=https://api.opticodds.com/api/v3

# Redis
REDIS_URL=redis://localhost:6379/0

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Shared token the extension sends in X-Extension-Token
EXTENSION_SHARED_TOKEN=dev-local-token

# Defaults — Optic uses display-case sportsbook names.
# "Circa Sports" has a space — quoted here for clarity.
DEFAULT_SHARP_BOOKS=Pinnacle,Betcris,BetOnline,Circa Sports
MIN_SHARP_BOOKS=2

EDGE_PLAYABLE_CENTS=2
EDGE_AVOID_CENTS=-2

# Cache TTLs (seconds)
CACHE_TTL_FIXTURES_ODDS=7
CACHE_TTL_FAIR=3

# Data source mode: "rest" or "stream"
ODDS_SOURCE=rest
STREAM_LEAGUES=MLB,NBA,NHL
